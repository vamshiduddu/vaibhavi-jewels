generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Admin & Auth ----------

enum AdminRole {
  super_admin
  admin
  sub_admin
  catalog_manager
  content_manager
  inventory_manager
  order_manager
  supervisor
  accounts_manager
  store_staff
  support
}

enum BarcodeType {
  code128
  code39
  qr
}

model AdminUser {
  id                 String           @id @default(cuid())
  email              String           @unique
  name               String
  passwordHash       String
  role               AdminRole        @default(support)
  roleLabel          String?
  grantedPermissions String[]         @default([])
  deniedPermissions  String[]         @default([])
  active             Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  stockAdjustments   StockAdjustment[]
  offlineSales       OfflineSale[]    @relation("OfflineSaleCreatedBy")
  purchaseRecords    PurchaseRecord[] @relation("PurchaseRecordCreatedBy")
}

// ---------- Customers ----------

model Customer {
  id        String    @id @default(cuid())
  email     String?   @unique
  phone     String?   @unique
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  addresses Address[]
  orders    Order[]
  reviews   Review[]
}

model Address {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String    @default("India")
  createdAt  DateTime  @default(now())
  orders     Order[]
}

// ---------- Catalog ----------

enum ProductStatus {
  draft
  active
  archived
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  description   String?
  image         String?
  sortOrder     Int           @default(0)
  active        Boolean       @default(true)
  seoTitle      String?
  seoDescription String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subcategories Subcategory[]
  products      Product[]
  promotions    Promotion[]
}

model Subcategory {
  id             String     @id @default(cuid())
  categoryId     String
  category       Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  description    String?
  image          String?
  sortOrder      Int        @default(0)
  active         Boolean    @default(true)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  products       Product[]
  promotions     Promotion[]

  @@unique([categoryId, slug])
}

model Collection {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String?
  image          String?
  sortOrder      Int         @default(0)
  active         Boolean     @default(true)
  featured       Boolean     @default(false)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  products       Product[]
  promotions     Promotion[]
}

model Product {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  shortDescription String?
  description      String?
  price            Decimal        @db.Decimal(10, 2)
  compareAtPrice   Decimal?       @db.Decimal(10, 2)
  purchaseCost     Decimal?       @db.Decimal(10, 2)
  weightGrams      Int            @default(250)
  sku              String?        @unique
  barcodeValue     String?        @unique
  barcodeType      BarcodeType    @default(code128)
  stockQuantity    Int            @default(0)
  lowStockThreshold Int           @default(3)
  categoryId       String?
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategoryId    String?
  subcategory      Subcategory?   @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  collectionId     String?
  collection       Collection?    @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  tags             String[]       @default([])
  status           ProductStatus  @default(draft)
  featured         Boolean        @default(false)
  badge            String?        // e.g. Sale, Limited Offer, Best Seller, New Arrival
  color            String?
  material         String?
  occasion         String?
  // limited-time product-level sale pricing window
  salePrice        Decimal?       @db.Decimal(10, 2)
  saleStartsAt     DateTime?
  saleEndsAt       DateTime?
  sortOrder        Int            @default(0)
  seoTitle         String?
  seoDescription   String?
  aiInstagramCaption String?
  aiYoutubeTitle   String?
  aiYoutubeDescription String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  images           ProductImage[]
  variants         ProductVariant[]
  attributes       ProductAttribute[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  reviews          Review[]
  promotions       Promotion[]
  stockAdjustments StockAdjustment[]
  wishlistItems    WishlistItem[]
  offlineSaleItems OfflineSaleItem[]
  purchaseItems    PurchaseRecordItem[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([collectionId])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  kind      String   @default("image") // image | video (youtube/instagram/facebook URL)
  sortOrder Int      @default(0)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String
  sku           String?  @unique
  price         Decimal? @db.Decimal(10, 2)
  stockQuantity Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
}

model ProductAttribute {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@unique([productId, name])
}

model StockAdjustment {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  adminId   String?
  admin     AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)
  source    String?
  createdAt DateTime @default(now())
}

// ---------- Cart ----------

model Cart {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  couponId  String?
  coupon    Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items     CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

// ---------- Orders & Payments ----------

enum OrderStatus {
  pending
  payment_pending
  paid
  processing
  packed
  shipped
  delivered
  cancelled
  refunded
}

enum OrderSource {
  online_store
  offline_store
  manual_admin
  whatsapp_order
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  addressId       String?
  address         Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  email           String?
  phone           String
  customerName    String
  status          OrderStatus @default(pending)
  source          OrderSource @default(online_store)
  subtotal        Decimal     @db.Decimal(10, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(10, 2)
  shippingTotal   Decimal     @default(0) @db.Decimal(10, 2)
  grandTotal      Decimal     @db.Decimal(10, 2)
  couponCode      String?
  promotionLabel  String?
  shippingPartner String?
  awbCode         String?
  shippingCode    String?
  internalNotes   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
  payments        Payment[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  title       String
  sku         String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  quantity    Int
  lineTotal   Decimal  @db.Decimal(10, 2)
  imageUrl    String?
}

enum PaymentStatus {
  initiated
  authorized
  paid
  failed
  refunded
}

enum OfflinePaymentMethod {
  cash
  card
  upi
  split_payment
  credit_pending
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          String        @default("razorpay")
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(initiated)
  rawPayload        Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Supplier {
  id              String           @id @default(cuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  notes           String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  purchaseRecords PurchaseRecord[]
}

model PurchaseRecord {
  id            String               @id @default(cuid())
  supplierId    String?
  supplier      Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  invoiceNumber String?
  purchaseDate  DateTime             @default(now())
  notes         String?
  totalCost     Decimal              @default(0) @db.Decimal(10, 2)
  createdById   String?
  createdBy     AdminUser?           @relation("PurchaseRecordCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  items         PurchaseRecordItem[]

  @@index([purchaseDate])
}

model PurchaseRecordItem {
  id               String         @id @default(cuid())
  purchaseRecordId String
  purchaseRecord   PurchaseRecord @relation(fields: [purchaseRecordId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity         Int
  unitCost         Decimal        @db.Decimal(10, 2)
  lineTotal        Decimal        @db.Decimal(10, 2)
}

model OfflineSale {
  id            String               @id @default(cuid())
  saleNumber    String               @unique
  customerName  String?
  phone         String?
  notes         String?
  paymentMethod OfflinePaymentMethod
  subtotal      Decimal              @db.Decimal(10, 2)
  discountTotal Decimal              @default(0) @db.Decimal(10, 2)
  grandTotal    Decimal              @db.Decimal(10, 2)
  createdById   String?
  createdBy     AdminUser?           @relation("OfflineSaleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  items         OfflineSaleItem[]

  @@index([createdAt])
}

model OfflineSaleItem {
  id            String      @id @default(cuid())
  offlineSaleId String
  offlineSale   OfflineSale @relation(fields: [offlineSaleId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  title         String
  sku           String?
  barcodeValue  String?
  quantity      Int
  unitPrice     Decimal     @db.Decimal(10, 2)
  lineTotal     Decimal     @db.Decimal(10, 2)
}

// ---------- Promotions & Coupons ----------

enum DiscountType {
  percentage
  fixed
}

enum PromotionScope {
  sitewide
  category
  subcategory
  collection
  product
}

model Promotion {
  id            String         @id @default(cuid())
  name          String
  label         String?        // badge/banner text e.g. "Festive Sale"
  scope         PromotionScope
  discountType  DiscountType
  discountValue Decimal        @db.Decimal(10, 2)
  categoryId    String?
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategoryId String?
  subcategory   Subcategory?   @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  collectionId  String?
  collection    Collection?    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?       @relation(fields: [productId], references: [id], onDelete: Cascade)
  minOrderValue Decimal?       @db.Decimal(10, 2)
  priority      Int            @default(0)
  active        Boolean        @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([active, scope])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usedCount     Int          @default(0)
  active        Boolean      @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  carts         Cart[]
}

// ---------- Content ----------

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  location  String   @default("homepage_hero") // homepage_hero, offer_strip, campaign
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique // announcement, hero, intro, new_arrivals, bridal, categories, payments, trust, contact
  title     String?
  kicker    String?
  body      String?
  ctaText   String?
  ctaUrl    String?
  imageUrl  String?
  config    Json?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---------- Reviews & Wishlist ----------

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  authorName String
  rating     Int
  body       String?
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model WishlistItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sessionId, productId])
}
